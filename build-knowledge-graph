def load_graph() -> dict:
    """Charge le graphe existant."""
    if os.path.exists(GRAPH_PATH):
        try:
            with open(GRAPH_PATH, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {"entities": {}, "meta": {"created": None, "updated": None, "files_processed": 0}}


def build_normalized_relations(graph: dict) -> list[dict]:
    """Extrait un array normalisé de relations depuis les entités.
    Format: [{source, target, type, reverse_type?}]
    Dédupliqué : chaque paire (source, target, type) n'apparaît qu'une fois.
    """
    seen = set()
    relations = []
    for entity_name, data in graph.get("entities", {}).items():
        for rel_type, targets in data.get("relations", {}).items():
            for target in targets:
                # Clé unique (triée pour éviter doublons bidirectionnels)
                key = tuple(sorted([entity_name, target])) + (rel_type,)
                if key not in seen:
                    seen.add(key)
                    relations.append({
                        "source": entity_name,
                        "target": target,
                        "type": rel_type,
                    })
    return relations


def save_graph(graph: dict):
    """Sauvegarde le graphe avec relations normalisées."""
    os.makedirs(os.path.dirname(GRAPH_PATH), exist_ok=True)
    graph["meta"]["updated"] = datetime.now().isoformat()
    # Construire le tableau normalisé de relations
    graph["relations"] = build_normalized_relations(graph)
    graph["meta"]["relation_count"] = len(graph["relations"])
    with open(GRAPH_PATH, "w") as f:
        json.dump(graph, f, ensure_ascii=False, indent=2)


def extract_entities_regex(content: str, filepath: str) -> list[dict]:
    """Extraction d'entités par regex (rapide, 0 coût)."""
    entities = []
    for entity_type, patterns in KNOWN_PATTERNS.items():
        for pattern in patterns:
            matches = re.finditer(pattern, content, re.IGNORECASE)
            for m in matches:
                name = m.group(0).strip()
                # Normaliser le nom (première lettre maj, sauf outils avec casse spécifique)
                name_norm = name
                if entity_type in ("client", "personne", "agent"):
                    name_norm = name.title()
                elif entity_type == "machine":
                    name_norm = name.title()
                # Normaliser les outils connus
                tool_norms = {"convex": "Convex", "vercel": "Vercel", "openclaw": "OpenClaw", 
                              "github": "GitHub", "ollama": "Ollama", "qmd": "QMD", "figma": "Figma",
                              "sentry": "Sentry", "cloudflare": "Cloudflare", "bureau": "Bureau",
                              "primask": "Primask", "next.js": "Next.js"}
                name_norm = tool_norms.get(name_norm.lower(), name_norm)
                entities.append({
                    "name": name_norm,
                    "type": entity_type,
                    "file": filepath,
                    "context": content[max(0, m.start()-50):m.end()+50].replace("\n", " ").strip(),
                })
    return entities


