def rerank_sonnet(query: str, results: list[dict], top_k: int = 5, debug: bool = False) -> list[dict]:
    """Rerank les résultats via GPT-4.1-mini (API OpenAI, ~$0.001/appel).
    Prend les top 15 de nomic et re-score chaque paire (query, chunk)."""
    if not results or len(results) <= top_k:
        return results
    
    api_key = get_openai_key()
    if not api_key:
        if debug:
            print("  ⚠ Pas de clé OpenAI — skip reranking", file=sys.stderr)
        return results[:top_k]
    
    # Construire le prompt de reranking
    items = []
    for i, r in enumerate(results[:15]):
        content = r.get("content", "")[:100].replace("\n", " ")
        items.append(f"{i+1}. [{r['file']}] {content}")
    
    prompt = f"""Score la pertinence de chaque résultat par rapport à la question.
Réponds UNIQUEMENT en JSON: [{{"idx": 1, "score": 0.95}}, ...]
Score de 0.0 (hors sujet) à 1.0 (répond directement).

Question: {query}

Résultats:
{chr(10).join(items)}"""
    
    try:
        import time
        t0 = time.time()
        payload = json.dumps({
            "model": "gpt-5.4-nano",
            "messages": [{"role": "user", "content": prompt}],
            "max_completion_tokens": 500
        })
        result = subprocess.run(
            ["curl", "-s", "https://api.openai.com/v1/chat/completions",
             "-H", f"Authorization: Bearer {api_key}",
             "-H", "Content-Type: application/json",
             "-d", payload],
            capture_output=True, text=True, timeout=15
        )
        response = json.loads(result.stdout)
        text = response.get("choices", [{}])[0].get("message", {}).get("content", "")
        elapsed = time.time() - t0
        
        # Extraire le JSON array
        start = text.find("[")
        end = text.rfind("]") + 1
        if start >= 0 and end > start:
            scores_list = json.loads(text[start:end])
            score_map = {s["idx"]: s["score"] for s in scores_list if "idx" in s and "score" in s}
            
            reranked = []
            for i, r in enumerate(results[:15]):
                new_score = score_map.get(i + 1, 0.0)
                r_copy = dict(r)
                r_copy["rerank_score"] = new_score
                r_copy["original_score"] = r.get("score", 0)
                r_copy["final_score"] = new_score
                reranked.append(r_copy)
            
            reranked.sort(key=lambda x: x["rerank_score"], reverse=True)
            
            if debug:
                top_items = [f"{r['file']}:{r['line']}={r['rerank_score']:.2f}" for r in reranked[:top_k]]
                print(f"  🔄 Reranked ({elapsed:.1f}s): {top_items}", file=sys.stderr)
            
            return reranked[:top_k]
    except Exception as e:
        if debug:
            print(f"  ⚠ Reranker exception: {e}", file=sys.stderr)
    
    # Fallback : retourner les top_k originaux
    return results[:top_k]


def search_nomic(query: str, chunks: list[dict], embeddings: list[list[float]], 
                 limit: int = RESULTS_PER_HOP, debug: bool = False,
                 rerank: bool = False) -> list[dict]:
    """Recherche sémantique via nomic embeddings. Avec reranking optionnel."""
    q_embs = embed_ollama([query])
    if not q_embs or not q_embs[0]:
        return []
    q_emb = q_embs[0]

    scores = []
    for i, (chunk, emb) in enumerate(zip(chunks, embeddings)):
        if not emb:
            continue
        sim = cosine_sim(q_emb, emb)
        scores.append((sim, chunk))

    scores.sort(key=lambda x: x[0], reverse=True)
    
    # Prendre plus de résultats si reranking activé (top 20 → rerank → top limit)
    fetch_limit = 20 if rerank else limit
    results = []
    for sim, chunk in scores[:fetch_limit]:
        results.append({
            "filepath": f"{WORKSPACE}/{chunk['file']}",
            "file": chunk["file"],
            "line": chunk["line"],
            "content": chunk["text"][:300],
            "score": round(sim, 4),
            "final_score": round(sim, 4),
            "zone": "nomic",
        })
    
    if rerank and len(results) > limit:
        results = rerank_sonnet(query, results, top_k=limit, debug=debug)
    
    return results


def format_results_for_llm(results: list[dict]) -> str:
    """Formate les résultats QMD pour le prompt LLM."""
    if not results:
        return "(aucun résultat)"
    
    workspace = "/Users/primostudio/.openclaw/workspace/"
    lines = []
    for i, r in enumerate(results, 1):
        path = r["filepath"].replace(workspace, "")
        content = r.get("content", "")[:300]  # Limiter la taille
        score = r.get("final_score", r.get("score", 0))
        zone = r.get("zone", "?")
        lines.append(f"{i}. [{zone}] {path}:{r['line']} (score: {score:.3f})\n   {content}")
    
    return "\n\n".join(lines)


def extract_json(text: str) -> dict | None:
    """Extrait le premier objet JSON valide d'un texte."""
    depth = 0
    start_idx = None
    for ci, ch in enumerate(text):
        if ch == '{':
            if depth == 0:
                start_idx = ci
            depth += 1
        elif ch == '}':
            depth -= 1
            if depth == 0 and start_idx is not None:
                try:
                    return json.loads(text[start_idx:ci+1])
                except json.JSONDecodeError:
                    start_idx = None
                    continue
    try:
        return json.loads(text)
    except (json.JSONDecodeError, ValueError):
        return None


def call_llm_claude(prompt: str, debug: bool = False) -> dict | None:
    """Appelle Claude Code (--print, $0 Max) pour le routage."""
    try:
        result = subprocess.run(
            ["/Users/primostudio/.local/bin/claude", "--print",
             "--permission-mode", "bypassPermissions",
             "--output-format", "text",
             "-p", f"Réponds UNIQUEMENT en JSON valide, rien d'autre. Pas de markdown, pas de ```.\n\n{prompt}"],
            capture_output=True, text=True, timeout=30
        )
        text = result.stdout.strip()
        if debug:
            print(f"  LLM (claude): {text[:200]}", file=sys.stderr)
        return extract_json(text)
    except (subprocess.TimeoutExpired, Exception) as e:
        if debug:
            print(f"  ⚠ Claude exception: {e}", file=sys.stderr)
        return None


def call_llm_ollama(prompt: str, model: str, debug: bool = False) -> dict | None:
    """Appelle un modèle Ollama local."""
    payload = json.dumps({
        "model": model,
        "prompt": f"/no_think\n{prompt}",
        "stream": False,
        "options": {
            "temperature": 0.1,
            "num_predict": 2048,
        }
    })
    try:
        result = subprocess.run(
            ["curl", "-s", OLLAMA_URL, "-d", payload],
            capture_output=True, text=True, timeout=60
        )
        if result.returncode != 0:
            return None
        response = json.loads(result.stdout)
        text = response.get("response", "")
        if debug:
            print(f"  LLM (ollama/{model}): {text[:200]}", file=sys.stderr)
        return extract_json(text)
    except (subprocess.TimeoutExpired, json.JSONDecodeError, Exception) as e:
        if debug:
            print(f"  ⚠ Ollama exception: {e}", file=sys.stderr)
        return None


def call_llm_openai(prompt: str, model: str = "gpt-5.4-nano", debug: bool = False) -> dict | None:
    """Appelle un modèle OpenAI API (GPT-5.4-nano par défaut)."""
    api_key = get_openai_key()
    if not api_key:
        if debug:
            print(f"  ⚠ Pas de clé OpenAI, fallback claude", file=sys.stderr)
        return call_llm_claude(prompt, debug=debug)
    
    try:
        import time
        t0 = time.time()
        payload = json.dumps({
            "model": model,
            "messages": [{"role": "user", "content": f"Réponds UNIQUEMENT en JSON valide, rien d'autre. Pas de markdown, pas de ```.\n\n{prompt}"}],
            "max_completion_tokens": 2000
        })
        result = subprocess.run(
            ["curl", "-s", "https://api.openai.com/v1/chat/completions",
             "-H", f"Authorization: Bearer {api_key}",
             "-H", "Content-Type: application/json",
             "-d", payload],
            capture_output=True, text=True, timeout=20
        )
        response = json.loads(result.stdout)
        if "error" in response:
            if debug:
                print(f"  ⚠ OpenAI error: {response['error']['message'][:80]}", file=sys.stderr)
            return call_llm_claude(prompt, debug=debug)
        
        text = response.get("choices", [{}])[0].get("message", {}).get("content", "")
        elapsed = time.time() - t0
        if debug:
            print(f"  LLM ({model}, {elapsed:.1f}s): {text[:200]}", file=sys.stderr)
        return extract_json(text)
    except Exception as e:
        if debug:
            print(f"  ⚠ OpenAI exception: {e}, fallback claude", file=sys.stderr)
        return call_llm_claude(prompt, debug=debug)


def call_llm(prompt: str, model: str, debug: bool = False) -> dict | None:
    """Dispatch vers le bon backend LLM."""
    if model in OPENAI_MODELS:
        return call_llm_openai(prompt, model, debug=debug)
    elif model in CLOUD_MODELS or model == "claude":
        return call_llm_claude(prompt, debug=debug)
    else:
        return call_llm_ollama(prompt, model, debug=debug)


def deduplicate_results(all_results: list[dict]) -> list[dict]:
    """Déduplique les résultats par filepath+line."""
    seen = set()
    unique = []
    for r in all_results:
        key = f"{r['filepath']}:{r['line']}"
        if key not in seen:
            seen.add(key)
            unique.append(r)
    return unique


def multihop_search(question: str, model: str, max_hops: int, debug: bool,
                    use_nomic: bool = False, nomic_chunks=None, nomic_embeddings=None,
                    use_rerank: bool = False) -> dict:
    """Exécute la recherche multi-hop."""
    
    all_results = []
    hops = []
    context_summary = ""
    
    # Charger le graphe de connaissances pour enrichir les résultats
    graph = load_knowledge_graph()
    
    # Hop 1 : recherche directe sur la question
    current_query = question
    
    for hop_num in range(1, max_hops + 1):
        if debug:
            src = "nomic" if use_nomic else "qmd"
            print(f"\n--- Hop {hop_num}/{max_hops} [{src}] ---", file=sys.stderr)
            print(f"  Query: {current_query}", file=sys.stderr)
        
        # Recherche
        start = time.time()
        if use_nomic and nomic_chunks and nomic_embeddings:
            results = search_nomic(current_query, nomic_chunks, nomic_embeddings, debug=debug, rerank=use_rerank)
        else:
            results = search_qmd(current_query, debug=debug)
        search_time = time.time() - start
        
        if debug:
            print(f"  Résultats: {len(results)} ({search_time:.1f}s)", file=sys.stderr)
        
        # Enrichir avec le graphe de connaissances (hop 1 uniquement)
        if hop_num == 1 and graph:
            graph_files = graph_expand(current_query, graph, debug=debug)
            if graph_files and use_nomic and nomic_chunks:
                # Ajouter les chunks des fichiers trouvés par le graphe
                for chunk in nomic_chunks:
                    if chunk["file"] in graph_files and not any(r["file"] == chunk["file"] and r["line"] == chunk["line"] for r in results):
                        results.append({
                            "filepath": f"{WORKSPACE}/{chunk['file']}",
                            "file": chunk["file"],
                            "line": chunk["line"],
                            "content": chunk["text"][:300],
                            "score": 0.5,  # Score fixe pour les résultats du graphe
                            "final_score": 0.5,
                            "zone": "graph",
                        })
                # Trier par score et garder top N
                results.sort(key=lambda x: x.get("final_score", 0), reverse=True)
                results = results[:RESULTS_PER_HOP + 3]  # Légèrement plus large avec le graphe
        
        all_results.extend(results)
        
        # Construire le prompt
        prompt = ORCHESTRATOR_PROMPT.format(
            context=context_summary or "(premier hop, pas de contexte précédent)",
            hop_num=hop_num,
            results=format_results_for_llm(results),
            question=question,
            sub_question_note=f"\nSOUS-QUESTION ACTUELLE : {current_query}" if current_query != question else ""
        )
        
        # Appeler le LLM
        start = time.time()
        llm_response = call_llm(prompt, model, debug=debug)
        llm_time = time.time() - start
        
        hop_info = {
            "hop": hop_num,
            "query": current_query,
            "results_count": len(results),
            "search_time_s": round(search_time, 2),
            "llm_time_s": round(llm_time, 2),
        }
        
        if llm_response is None:
            # LLM a échoué → on fait la synthèse avec ce qu'on a
            hop_info["llm_action"] = "error"
            hops.append(hop_info)
            if debug:
                print(f"  ⚠ LLM a échoué, synthèse forcée", file=sys.stderr)
            break
        
        action = llm_response.get("action", "answer")
        hop_info["llm_action"] = action
        
        if action == "answer":
            # Le LLM a trouvé assez d'info → réponse finale
            hop_info["answer"] = llm_response.get("answer", "")
            hop_info["confidence"] = llm_response.get("confidence", 0)
            hop_info["sources"] = llm_response.get("sources", [])
            hops.append(hop_info)
            
            if debug:
                print(f"  ✅ Réponse trouvée (confiance: {hop_info['confidence']})", file=sys.stderr)
            
            return {
                "question": question,
                "answer": llm_response.get("answer", ""),
                "confidence": llm_response.get("confidence", 0),
                "sources": llm_response.get("sources", []),
                "hops": hops,
                "total_results": len(deduplicate_results(all_results)),
                "model": model,
            }
        
        elif action == "search":
            # Le LLM veut chercher encore
            next_query = llm_response.get("query", "")
            reason = llm_response.get("reason", "")
            
            if not next_query or next_query == current_query:
                # Sous-question vide ou identique → forcer une réponse
                hop_info["note"] = "sous-question identique ou vide, arrêt"
                hops.append(hop_info)
                if debug:
                    print(f"  ⚠ Sous-question identique, arrêt", file=sys.stderr)
                break
            
            hop_info["next_query"] = next_query
            hop_info["reason"] = reason
            hops.append(hop_info)
            
            # Mettre à jour le contexte pour le prochain hop
            context_summary += f"\nHop {hop_num}: cherché '{current_query}' → {len(results)} résultats. {reason}"
            current_query = next_query
            
            if debug:
                print(f"  🔄 Sous-question: {next_query}", file=sys.stderr)
                print(f"     Raison: {reason}", file=sys.stderr)
        
        else:
            # Action inconnue
            hop_info["note"] = f"action inconnue: {action}"
            hops.append(hop_info)
            break
    
    # Si on arrive ici sans réponse → synthèse forcée avec tout ce qu'on a
    if debug:
        print(f"\n--- Synthèse forcée ({len(deduplicate_results(all_results))} résultats uniques) ---", file=sys.stderr)
    
    unique_results = deduplicate_results(all_results)
    
    # Demander au LLM une synthèse finale
    synthesis_prompt = f"""Tu as fait {len(hops)} recherches pour répondre à cette question.
Voici TOUS les résultats collectés :

{format_results_for_llm(unique_results[:10])}

QUESTION : {question}

Réponds avec ce que tu sais. Si l'info est incomplète, dis-le.
Format JSON : {{"action": "answer", "answer": "...", "confidence": 0.5, "sources": [...]}}"""
    
    final = call_llm(synthesis_prompt, model, debug=debug)
    
    answer = ""
    confidence = 0
    sources = []
    
    if final and final.get("action") == "answer":
        answer = final.get("answer", "Information insuffisante dans le workspace.")
        confidence = final.get("confidence", 0.3)
        sources = final.get("sources", [])
    else:
        answer = "Recherche multi-hop terminée sans réponse concluante. Résultats partiels disponibles."
        confidence = 0.2
    
    return {
        "question": question,
        "answer": answer,
        "confidence": confidence,
        "sources": sources,
        "hops": hops,
        "total_results": len(unique_results),
        "model": model,
        "forced_synthesis": True,
    }


def main():
    args = sys.argv[1:]
    
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)
    
    question = args[0]
    model = DEFAULT_MODEL
    max_hops = MAX_HOPS
    debug = False
    as_json = False
    use_nomic = True  # Nomic par défaut maintenant
    use_rerank = False
    
    i = 1
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]
            i += 2
        elif args[i] == "--max-hops" and i + 1 < len(args):
            try:
                max_hops = int(args[i + 1])
            except ValueError:
                print(f"ERREUR: --max-hops attend un nombre", file=sys.stderr)
                sys.exit(1)
            i += 2
        elif args[i] == "--embed" and i + 1 < len(args):
            embed_choice = args[i + 1].lower()
            use_nomic = embed_choice in ("nomic", "nomic-v2", "nomic-v2-moe")
            i += 2
        elif args[i] == "--qmd":
            use_nomic = False
            i += 1
        elif args[i] == "--rerank":
            use_rerank = True
            i += 1
        elif args[i] == "--debug":
            debug = True
            i += 1
        elif args[i] == "--json":
            as_json = True
            i += 1
        else:
            i += 1
    
    # Vérifier Ollama (nécessaire pour nomic embed ou modèles locaux)
    if not check_ollama():
        if use_nomic:
            print("⚠ Ollama requis pour nomic embed. Fallback → QMD.", file=sys.stderr)
            use_nomic = False
        if model not in CLOUD_MODELS:
            print("⚠ Ollama n'est pas accessible. Utilisez --model sonnet.", file=sys.stderr)
            sys.exit(1)
    
    # Charger les embeddings nomic si besoin
    nomic_chunks = None
    nomic_embeddings = None
    if use_nomic:
        cache_start = time.time()
        nomic_chunks, nomic_embeddings = build_or_load_embed_cache(debug=debug)
        if debug:
            print(f"  Embed cache: {len(nomic_chunks)} chunks en {time.time()-cache_start:.1f}s", file=sys.stderr)
    
    # Lancer la recherche
    start = time.time()
    result = multihop_search(question, model, max_hops, debug,
                             use_nomic=use_nomic, nomic_chunks=nomic_chunks, 
                             nomic_embeddings=nomic_embeddings,
                             use_rerank=use_rerank)
    total_time = time.time() - start
    result["total_time_s"] = round(total_time, 2)
    result["embed"] = "nomic-v2-moe" if use_nomic else "qmd"
    
    if as_json:
        print(json.dumps(result, ensure_ascii=False, indent=2))
    else:
        # Affichage humain
        print(f"\n💡 {result['answer']}")
        print(f"\n📊 Confiance: {result['confidence']:.0%} | Hops: {len(result['hops'])} | Résultats: {result['total_results']} | Temps: {total_time:.1f}s")
        if result.get('sources'):
            print(f"📎 Sources: {', '.join(result['sources'])}")
        if result.get('forced_synthesis'):
            print(f"⚠ Synthèse forcée (max hops atteint)")


if __name__ == "__main__":
    main()
