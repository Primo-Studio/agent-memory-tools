def load_knowledge_graph() -> dict:
    """Charge le graphe de connaissances pour enrichir les recherches."""
    try:
        import os
        if os.path.exists(GRAPH_PATH):
            with open(GRAPH_PATH, "r") as f:
                return json.load(f)
    except Exception:
        pass
    return {}


def graph_expand(query: str, graph: dict, debug: bool = False) -> list[str]:
    """Utilise le graphe pour trouver des fichiers liés aux entités mentionnées dans la query."""
    if not graph or "entities" not in graph:
        return []
    
    extra_files = []
    query_lower = query.lower()
    
    for name, data in graph["entities"].items():
        if name.lower() in query_lower:
            # Entité trouvée dans la query → ajouter ses fichiers
            extra_files.extend(data.get("mentions", []))
            # Aussi les fichiers des voisins (relations)
            for rel_type, targets in data.get("relations", {}).items():
                for target in targets:
                    if target in graph["entities"]:
                        extra_files.extend(graph["entities"][target].get("mentions", [])[:2])
            if debug:
                rels = list(data.get("relations", {}).keys())
                print(f"  📊 Graphe: '{name}' → {len(data.get('mentions',[]))} fichiers, relations: {rels}", file=sys.stderr)
    
    return list(set(extra_files))


