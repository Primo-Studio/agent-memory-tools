def embed_ollama(texts: list[str], model: str = DEFAULT_EMBED_MODEL) -> list[list[float]]:
    """Embed une liste de textes via Ollama."""
    try:
        result = subprocess.run(
            ["curl", "-s", OLLAMA_EMBED_URL, "-d",
             json.dumps({"model": model, "input": texts})],
            capture_output=True, text=True, timeout=120
        )
        data = json.loads(result.stdout)
        return data.get("embeddings", [])
    except Exception:
        return []


def cosine_sim(a: list[float], b: list[float]) -> float:
    """Similarité cosinus."""
    dot = sum(x * y for x, y in zip(a, b))
    na = sum(x * x for x in a) ** 0.5
    nb = sum(x * x for x in b) ** 0.5
    return dot / (na * nb) if na and nb else 0.0


def load_workspace_chunks() -> list[dict]:
    """Charge et chunke les fichiers .md du workspace."""
    import os, glob
    chunks = []
    md_files = glob.glob(f"{WORKSPACE}/**/*.md", recursive=True)
    # Filtrer les dossiers non pertinents
    skip = [".cache", "node_modules", "brain/references", "docs/web"]
    for fpath in sorted(md_files):
        relpath = fpath.replace(WORKSPACE + "/", "")
        if any(s in relpath for s in skip):
            continue
        try:
            with open(fpath, "r") as f:
                content = f.read()
            if not content.strip():
                continue
            # Chunk par sections (## headers) ou par ~500 chars
            lines = content.split("\n")
            chunk_lines = []
            chunk_start = 1
            for i, line in enumerate(lines, 1):
                if line.startswith("## ") and chunk_lines and len("\n".join(chunk_lines)) > 100:
                    text = "\n".join(chunk_lines)[:800]
                    chunks.append({"file": relpath, "line": chunk_start, "text": text})
                    chunk_lines = [line]
                    chunk_start = i
                else:
                    chunk_lines.append(line)
                    # Force split at ~600 chars
                    if len("\n".join(chunk_lines)) > 600:
                        text = "\n".join(chunk_lines)[:800]
                        chunks.append({"file": relpath, "line": chunk_start, "text": text})
                        chunk_lines = []
                        chunk_start = i + 1
            if chunk_lines and len("\n".join(chunk_lines).strip()) > 20:
                text = "\n".join(chunk_lines)[:800]
                chunks.append({"file": relpath, "line": chunk_start, "text": text})
        except Exception:
            continue
    return chunks


def build_or_load_embed_cache(debug: bool = False) -> tuple[list[dict], list[list[float]]]:
    """Charge le cache d'embeddings ou le construit."""
    import os
    os.makedirs(os.path.dirname(EMBED_CACHE_PATH), exist_ok=True)

    chunks = load_workspace_chunks()
    chunk_texts = [c["text"] for c in chunks]

    # Vérifier si le cache est encore valide (même nombre de chunks)
    if os.path.exists(EMBED_CACHE_PATH):
        try:
            with open(EMBED_CACHE_PATH, "r") as f:
                cache = json.load(f)
            if cache.get("count") == len(chunks) and cache.get("model") == DEFAULT_EMBED_MODEL:
                if debug:
                    print(f"  📦 Cache chargé ({len(chunks)} chunks)", file=sys.stderr)
                return chunks, cache["embeddings"]
        except Exception:
            pass

    # Construire les embeddings par batch de 20
    if debug:
        print(f"  🔄 Embedding {len(chunks)} chunks avec {DEFAULT_EMBED_MODEL}...", file=sys.stderr)
    
    all_embeddings = []
    batch_size = 20
    for i in range(0, len(chunk_texts), batch_size):
        batch = chunk_texts[i:i+batch_size]
        embs = embed_ollama(batch)
        all_embeddings.extend(embs)
        if debug:
            print(f"    Batch {i//batch_size+1}/{(len(chunk_texts)-1)//batch_size+1} ({len(embs)} embeddings)", file=sys.stderr)

    if len(all_embeddings) != len(chunks):
        if debug:
            print(f"  ⚠ Embedding incomplet: {len(all_embeddings)}/{len(chunks)}", file=sys.stderr)
        # Pad with empty
        while len(all_embeddings) < len(chunks):
            all_embeddings.append([])

    # Sauvegarder le cache
    try:
        with open(EMBED_CACHE_PATH, "w") as f:
            json.dump({"model": DEFAULT_EMBED_MODEL, "count": len(chunks), "embeddings": all_embeddings}, f)
        if debug:
            print(f"  💾 Cache sauvegardé ({len(chunks)} chunks)", file=sys.stderr)
    except Exception as e:
        if debug:
            print(f"  ⚠ Cache save error: {e}", file=sys.stderr)

    return chunks, all_embeddings


