#!/usr/bin/env python3
"""
qmd-decay-query — Wrapper QMD avec decay temporel intelligent.
Phase 3 du plan mémoire avancée.

Usage:
    qmd-decay-query "ma recherche" [--limit 10] [--raw] [--debug]

Flags:
    --limit N    Nombre max de résultats (défaut: 10)
    --raw        Affiche les scores bruts QMD (sans decay)
    --debug      Affiche le détail du calcul de decay
    --json       Sortie JSON (pour intégration programmatique)

Le decay s'applique UNIQUEMENT aux contenus épisodiques/datés.
Les faits durables (savoir, erreurs, préférences) sont protégés.
"""

import subprocess
import json
import sys
import re
import math
from datetime import datetime, timezone, timedelta
from pathlib import Path

# ─── Configuration ───────────────────────────────────────────────
HALF_LIFE_DAYS = 14          # Un événement perd 50% de son score en 14 jours
HALF_LIFE_DAYS_PROJECTS = 30 # Les projets décayent plus lentement (30 jours)
ERROR_BOOST = 1.2            # Les erreurs critiques sont boostées de 20%
MIN_DECAY_FACTOR = 0.3       # Un résultat ne descend jamais sous 30% de son score original
QMD_PATH = "/Users/primostudio/.bun/bin/qmd"
WORKSPACE = "/Users/primostudio/.openclaw/workspace"

# ─── Zones protégées (pas de decay) ─────────────────────────────
PROTECTED_FILES = {
    "USER.md",        # Préférences Neto = durables
    "TOOLS.md",       # Configs/tokens = factuels
    "IDENTITY.md",    # Identité = permanente
    "SOUL.md",        # Personnalité = permanente
    "AGENTS.md",      # Règles de fonctionnement = permanentes
    "HEARTBEAT.md",   # Checklist = permanente
}

# Patterns de fichiers toujours protégés (regex)
PROTECTED_PATTERNS = [
    r"agents/prompts/",       # Prompts = templates permanents
    r"bugs/",                 # Bugs documentés = leçons permanentes
    r"docs/web/",             # Références techniques = permanentes
    r"etudes/",               # Études = permanentes
    r"infra/",                # Config infra = factuelle
    r"modules-bureau/",       # Doc modules = permanente
]

# ─── Zones avec decay ───────────────────────────────────────────
DECAY_PATTERNS = [
    r"memory/\d{4}-\d{2}-\d{2}\.md",   # Daily logs = épisodiques
    r"factures-2026/",                   # Factures = datées
    r"echanges/",                        # Échanges inter-agents = datés
]

# ─── Détection de zone dans MEMORY.md ───────────────────────────
def detect_memory_zone(content: str, line_num: int, file_lines: list[str] | None = None) -> str:
    """
    Détecte la zone d'un résultat dans MEMORY.md.
    Remonte les lignes pour trouver le header de zone le plus proche.
    """
    if file_lines is None:
        return "unknown"

    zone_markers = {
        "📌 Navigation": "navigation",
        "🧠 Savoir": "savoir",
        "❌ Erreurs": "erreurs",
        "📅 Chronologie": "chronologie",
    }

    # Remonter depuis la ligne du résultat pour trouver la zone
    for i in range(min(line_num - 1, len(file_lines) - 1), -1, -1):
        line = file_lines[i]
        for marker, zone in zone_markers.items():
            if marker in line:
                return zone

    return "unknown"


def extract_date_from_content(content: str) -> datetime | None:
    """
    Tente d'extraire une date du contenu.
    Supporte : JJ/MM/AAAA, AAAA-MM-DD, **JJ/MM**
    """
    patterns = [
        (r"(\d{4})-(\d{2})-(\d{2})", lambda m: f"{m.group(1)}-{m.group(2)}-{m.group(3)}"),
        (r"(\d{2})/(\d{2})/(\d{4})", lambda m: f"{m.group(3)}-{m.group(2)}-{m.group(1)}"),
        (r"\*\*(\d{2})/(\d{2})\*\*", lambda m: f"{datetime.now().year}-{m.group(2)}-{m.group(1)}"),  # **JJ/MM** → année courante
    ]

    for pattern, formatter in patterns:
        match = re.search(pattern, content)
        if match:
            try:
                date_str = formatter(match)
                return datetime.strptime(date_str, "%Y-%m-%d").replace(tzinfo=timezone(timedelta(hours=-3)))
            except ValueError:
                continue

    return None


def extract_date_from_filename(filepath: str) -> datetime | None:
    """Extrait la date d'un fichier memory/YYYY-MM-DD.md"""
    match = re.search(r"memory/(\d{4}-\d{2}-\d{2})\.md", filepath)
    if match:
        try:
            return datetime.strptime(match.group(1), "%Y-%m-%d").replace(tzinfo=timezone(timedelta(hours=-3)))
        except ValueError:
            return None
    return None


def compute_decay(age_days: float, half_life: float = None) -> float:
    """
    Decay exponentiel avec demi-vie.
    score_final = score × decay_factor
    decay_factor = max(MIN_DECAY_FACTOR, 2^(-age/half_life))
    """
    if half_life is None:
        half_life = HALF_LIFE_DAYS
    if age_days <= 0:
        return 1.0
    raw_decay = math.pow(2, -age_days / half_life)
    return max(MIN_DECAY_FACTOR, raw_decay)


def classify_result(filepath: str, content: str, line_num: int) -> dict:
    """
    Classifie un résultat QMD et détermine s'il doit décayer.
    Retourne: {"decay": bool, "boost": float, "reason": str, "zone": str}
    """
    filename = Path(filepath).name
    rel_path = filepath.replace(WORKSPACE + "/", "")

    # 1. Fichiers protégés par nom (case-insensitive, QMD peut renvoyer en minuscule)
    if filename.upper() in {f.upper() for f in PROTECTED_FILES}:
        return {"decay": False, "boost": 1.0, "reason": "fichier protégé", "zone": "permanent"}

    # 2. Fichiers protégés par pattern
    for pattern in PROTECTED_PATTERNS:
        if re.search(pattern, rel_path):
            return {"decay": False, "boost": 1.0, "reason": f"dossier protégé ({pattern})", "zone": "permanent"}

    # 3. MEMORY.md — dépend de la zone
    if filename.upper() == "MEMORY.MD":
        try:
            if not hasattr(classify_result, '_cache'):
                classify_result._cache = {}
            if filepath not in classify_result._cache:
                with open(filepath, "r") as f:
                    classify_result._cache[filepath] = f.readlines()
            lines = classify_result._cache[filepath]
            zone = detect_memory_zone(content, line_num, lines)
        except (FileNotFoundError, PermissionError):
            zone = "unknown"

        if zone == "savoir":
            return {"decay": False, "boost": 1.0, "reason": "MEMORY.md zone 🧠 Savoir", "zone": "savoir"}
        elif zone == "erreurs":
            return {"decay": False, "boost": ERROR_BOOST, "reason": "MEMORY.md zone ❌ Erreurs (boost)", "zone": "erreurs"}
        elif zone == "navigation":
            return {"decay": False, "boost": 1.0, "reason": "MEMORY.md zone 📌 Navigation", "zone": "navigation"}
        elif zone == "chronologie":
            return {"decay": True, "boost": 1.0, "reason": "MEMORY.md zone 📅 Chronologie", "zone": "chronologie"}
        else:
            return {"decay": False, "boost": 1.0, "reason": "MEMORY.md zone inconnue (protégé par défaut)", "zone": "unknown"}

    # 4. COMPANY.md — données business, certaines datées
    if filename.upper() == "COMPANY.MD":
        # CA, chiffres datés → léger decay. Reste → protégé.
        if re.search(r"CA\s+\d{4}|\d+\s*K€|marge\s+RH|chiffre\s+d.affaire", content):
            return {"decay": True, "boost": 1.0, "reason": "COMPANY.md données chiffrées datées", "zone": "business-daté"}
        return {"decay": False, "boost": 1.0, "reason": "COMPANY.md info permanente", "zone": "business"}

    # 5. Fichiers épisodiques (memory/, factures/, échanges/)
    for pattern in DECAY_PATTERNS:
        if re.search(pattern, rel_path):
            return {"decay": True, "boost": 1.0, "reason": f"fichier épisodique ({pattern})", "zone": "épisodique"}

    # 6. Projets — semi-protégés (decay plus lent : demi-vie 30j au lieu de 14j)
    if re.search(r"projects/", rel_path):
        return {"decay": True, "boost": 1.0, "reason": "projet (decay léger, half-life 30j)", "zone": "projet", "half_life": HALF_LIFE_DAYS_PROJECTS}

    # 7. Défaut → protégé (mieux vaut conserver que perdre)
    return {"decay": False, "boost": 1.0, "reason": "défaut (protégé)", "zone": "inconnu"}


def run_qmd_search(query: str, limit: int) -> list[dict]:
    """Exécute qmd search et parse la sortie."""
    try:
        result = subprocess.run(
            [QMD_PATH, "search", query, "--limit", str(limit * 2)],  # 2x pour compenser les résultats qui vont baisser
            capture_output=True, text=True, timeout=30
        )
    except FileNotFoundError:
        print(f"ERREUR: QMD non trouvé à {QMD_PATH}", file=sys.stderr)
        sys.exit(1)
    except subprocess.TimeoutExpired:
        print("ERREUR: QMD timeout (30s)", file=sys.stderr)
        sys.exit(1)

    if result.returncode != 0:
        print(f"ERREUR QMD: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    # Parser la sortie QMD
    # Format réel:
    #   qmd://workspace/path/to/file.md:42 #hexcolor
    #   Title: ...
    #   Score:  24%
    #   (blank)
    #   @@ -1,3 @@ (0 before, 24 after)
    #   content lines...
    #   (blank = séparateur de résultat)
    results = []
    current = None
    in_content = False

    for line in result.stdout.split("\n"):
        # Nouvelle entrée : qmd://workspace/path:line #color
        match = re.match(r"^qmd://workspace/(.+?):(\d+)\s+#", line)
        if match:
            if current:
                results.append(current)
            filepath = WORKSPACE + "/" + match.group(1)
            current = {
                "score": 0.0,
                "filepath": filepath,
                "line": int(match.group(2)),
                "content": "",
            }
            in_content = False
            continue

        if current is None:
            continue

        # Score line: "Score:  24%"
        score_match = re.match(r"^Score:\s+([\d.]+)%", line)
        if score_match:
            current["score"] = float(score_match.group(1)) / 100.0
            continue

        # Hunk header: @@ -1,3 @@ (...)
        if line.startswith("@@"):
            in_content = True
            continue

        # Content lines (after @@)
        if in_content and line.strip():
            if current["content"]:
                current["content"] += " " + line.strip()
            else:
                current["content"] = line.strip()
        
        # Blank line in content — don't stop, QMD content can have blank lines
        # Content ends when next qmd:// header, Title:, Score:, or @@ appears

    if current:
        results.append(current)

    # Warning si QMD a retourné du contenu mais aucun résultat parsé
    if result.stdout.strip() and not results:
        print("⚠ QMD a retourné du contenu mais le parser n'a rien trouvé. "
              "Le format de sortie QMD a peut-être changé.", file=sys.stderr)

    return results


def apply_decay(results: list[dict], debug: bool = False) -> list[dict]:
    """Applique le decay temporel aux résultats QMD."""
    now = datetime.now(timezone(timedelta(hours=-3)))
    processed = []
    _file_cache: dict[str, list[str]] = {}  # Cache pour éviter de relire les fichiers N fois

    for r in results:
        classification = classify_result(r["filepath"], r["content"], r["line"])
        original_score = r["score"]
        decay_factor = 1.0
        age_days = None

        if classification["decay"]:
            # Trouver la date du contenu
            date = extract_date_from_content(r["content"])
            if date is None:
                date = extract_date_from_filename(r["filepath"])

            half_life = classification.get("half_life", HALF_LIFE_DAYS)
            if date:
                age_days = (now - date).total_seconds() / 86400
                decay_factor = compute_decay(age_days, half_life)
            else:
                # Pas de date trouvée → decay conservateur (assume 7 jours)
                age_days = 7
                decay_factor = compute_decay(7, half_life)

        # Appliquer decay + boost
        final_score = original_score * decay_factor * classification["boost"]

        entry = {
            **r,
            "original_score": original_score,
            "final_score": round(final_score, 4),
            "decay_factor": round(decay_factor, 4),
            "boost": classification["boost"],
            "zone": classification["zone"],
            "reason": classification["reason"],
            "age_days": round(age_days, 1) if age_days is not None else None,
        }
        processed.append(entry)

        if debug:
            age_str = f"{age_days:.0f}j" if age_days else "N/A"
            print(f"  [{classification['zone']:12s}] {original_score:.3f} → {final_score:.3f} "
                  f"(decay={decay_factor:.2f} boost={classification['boost']:.1f} age={age_str}) "
                  f"| {classification['reason']}", file=sys.stderr)

    # Trier par score final décroissant
    processed.sort(key=lambda x: x["final_score"], reverse=True)
    return processed


def format_output(results: list[dict], limit: int, raw: bool, as_json: bool) -> str:
    """Formate la sortie pour l'affichage."""
    results = results[:limit]

    if as_json:
        return json.dumps(results, ensure_ascii=False, indent=2)

    lines = []
    for r in results:
        rel_path = r["filepath"].replace(WORKSPACE + "/", "")
        if raw:
            lines.append(f"{r['original_score']:.3f} | {rel_path}:{r['line']} | {r['content'][:120]}")
        else:
            decay_info = ""
            if r["decay_factor"] < 1.0:
                decay_info = f" ↓{r['decay_factor']:.2f}"
            elif r["boost"] > 1.0:
                decay_info = f" ↑{r['boost']:.1f}"

            lines.append(f"{r['final_score']:.3f}{decay_info} [{r['zone']:8s}] | {rel_path}:{r['line']} | {r['content'][:120]}")

    return "\n".join(lines)


def main():
    args = sys.argv[1:]

    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    query = args[0]
    limit = 10
    raw = False
    debug = False
    as_json = False

    i = 1
    while i < len(args):
        if args[i] == "--limit" and i + 1 < len(args):
            try:
                limit = int(args[i + 1])
            except ValueError:
                print(f"ERREUR: --limit attend un nombre, reçu '{args[i + 1]}'", file=sys.stderr)
                sys.exit(1)
            i += 2
        elif args[i] == "--raw":
            raw = True
            i += 1
        elif args[i] == "--debug":
            debug = True
            i += 1
        elif args[i] == "--json":
            as_json = True
            i += 1
        else:
            i += 1

    if debug:
        print(f"Query: {query}", file=sys.stderr)
        print(f"Half-life: {HALF_LIFE_DAYS} jours | Min decay: {MIN_DECAY_FACTOR} | Error boost: {ERROR_BOOST}", file=sys.stderr)
        print("---", file=sys.stderr)

    results = run_qmd_search(query, limit)

    if not results:
        if as_json:
            print("[]")
        else:
            print("Aucun résultat.")
        sys.exit(0)

    if raw:
        print(format_output(results, limit, raw=True, as_json=as_json))
    else:
        processed = apply_decay(results, debug=debug)
        print(format_output(processed, limit, raw=False, as_json=as_json))


if __name__ == "__main__":
    main()
